<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Mobile Parallel Suite" parallel="tests" thread-count="3">

<!--    <listeners>-->
<!--        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>-->
<!--    </listeners>-->

    <!-- ANDROID -->
    <test name="Android Emulator">
        <parameter name="platform" value="android"/>
        <parameter name="udid" value="emulator-5554"/>
        <parameter name="systemPort" value="8200"/>
        <parameter name="appiumPort" value="10000"/>

        <classes>
            <class name="com.mobileAutomation.runners.AndroidRunner"/>
        </classes>
    </test>

    <!-- IOS DEVICE 1 -->
    <test name="iPhone 16e">
        <parameter name="platform" value="ios"/>
        <parameter name="udid" value="4595B892-F20A-4471-A44C-48F1D90D4008"/>
        <parameter name="wdaLocalPort" value="8100"/>
        <parameter name="appiumPort" value="10001"/>

        <classes>
            <class name="com.mobileAutomation.runners.IOSRunner"/>
        </classes>
    </test>

    <!-- IOS DEVICE 2 -->
    <test name="iPhone 17">
        <parameter name="platform" value="ios"/>
        <parameter name="udid" value="86ACDF00-9AF0-4A80-A84C-8D75F7D5BEC0"/>
        <parameter name="wdaLocalPort" value="8101"/>
        <parameter name="appiumPort" value="10002"/>
        <classes>
            <class name="com.mobileAutomation.runners.IOSRunner"/>
        </classes>
    </test>

</suite>
